<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
         <link rel="stylesheet" href="{{ asset('assets/styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
        {% endblock %}

    
    </head>
        
    <body>
        
        <nav class="navbar">

                <div class="navbar-left">
                    <a href="{{ path('home') }}" class="logo">
                        <img src="{{ asset('images/logo.png') }}" width="75">
                    </a>
                    <span class="slogan">Don't compromise on your look</span>

                 {% if app.user %}
                    <span class="greeting">{{ "now"|date("H", "Europe/Paris") < 18 ? "Bonjour" : "Bonsoir" }} {{ app.user.name }}</span>
                {% endif %}
                 
                 <!--  Icône burger -->
                 <div class="burger" id="burger">☰</div>

                </div>

                <div class="navbar-right" id="menu">
                    <a href="{{ path('home') }}">Accueil</a>

                    {% if app.user %}
                        
                        <a href="{{ path('products') }}">Boutique</a>

                        {% set cart = app.user.getCurrentCart() %}
                        <a href="{{ path('cart') }}">Panier ({{ cart ? cart.cartItems|length : 0 }})</a>
                        <a href="{{ path('app_logout') }}">Déconnexion</a>

                    {% else %}
                        <a href="{{ path('app_login') }}">Connexion</a>
                        <a href="{{ path('app_register') }}">Inscription</a>
                    {% endif %}
                </div>

        </nav>

        {# Bloc d'affichage des alertes globales #}
        <div class="flash-container" id="flash-container">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
        </div>
        
         {% block body %}{% endblock %}

        <footer>
    
                <p><strong>Stubborn</strong></p>

                <p>Email : contact@stubborn.com</p>

                <p>Adresse : Paris, France</p>

                <p>© {{ "now"|date("Y") }} Stubborn - Tous droits réservés</p>

        </footer>

        <script>
        const burger = document.getElementById('burger');
        const menu = document.getElementById('menu');

        burger.addEventListener('click', () => {
            menu.classList.toggle('active');
        });

        // Supprime le message au bout de 10 secondes
        setTimeout(() => {
            const flash = document.getElementById('flash-container');
            if(flash) {
                flash.style.display = 'none';
            }
        }, 10000); // 10000ms = 10 secondes

   </script>
        
        
    </body>

    
</html>
