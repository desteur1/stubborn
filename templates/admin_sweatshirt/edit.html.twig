{% extends 'base.html.twig' %}

{% block title %}Modifier Sweat-shirt{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('assets/styles/edit.css') }}">
{% endblock %}

{% block body %}
<div class="form-container">
<h1>Modifier : {{ sweatshirt.name }}</h1>

{{ form_start(form) }}
    {{ form_widget(form) }}
    <button class="btn btn-success">Mettre à jour</button>
{{ form_end(form) }}

<a href="{{ path('app_admin_sweatshirt') }}">Retour à la liste</a>
</div>
{% endblock %}